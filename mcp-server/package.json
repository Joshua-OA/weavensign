{
  "name": "@weavensign/mcp-server",
  "version": "0.1.0",
  "description": "MCP tool definitions and stdio transport exposing the Figma/Penpot adapters and normalization layer to MCP clients",
  "license": "GPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "weavensign-mcp-server": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@weavensign/adapter-figma": "0.1.0",
    "@weavensign/adapter-penpot": "0.1.0",
    "@weavensign/normalization": "0.1.0",
    "@weavensign/schema": "0.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.14.15",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
